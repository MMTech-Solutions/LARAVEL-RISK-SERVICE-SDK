{
    "name": "mmtech/mmt-risk-sdk",
    "description": "PHP SDK for MMT Risk Management Service API. Uses Laravel HTTP client (Guzzle). Laravel 11–13 compatible.",
    "type": "library",
    "license": "proprietary",
    "keywords": [
        "mmt",
        "risk",
        "laravel",
        "guzzle",
        "rest"
    ],
    "authors": [
        {
            "name": "MMT Risk Management Service"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "MmtRiskSdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MmtRiskSdk\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MmtRiskSdk\\Laravel\\MmtRiskSdkServiceProvider"
            ],
            "aliases": {
                "MmtRisk": "MmtRiskSdk\\Laravel\\Facades\\MmtRisk"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "@php vendor/phpunit/phpunit/phpunit"
    }
}
