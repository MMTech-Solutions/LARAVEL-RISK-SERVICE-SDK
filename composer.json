{
    "name": "mmtech/mmt-risk-sdk",
    "version": "1.2.0",
    "description": "PHP SDK for MMT Risk Management Service API (Guzzle transport, typed commands and responses). Laravel 11–13 compatible.",
    "type": "library",
    "license": "proprietary",
    "keywords": [
        "mmt",
        "risk",
        "laravel",
        "guzzle",
        "rest"
    ],
    "authors": [
        {
            "name": "MMT Risk Management Service"
        }
    ],
    "require": {
        "php": "^8.3",
        "guzzlehttp/guzzle": "^7.2",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "MmtRiskSdk\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MmtRiskSdk\\MmtRiskSdkServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
